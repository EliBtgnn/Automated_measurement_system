% impotring data
filename = 'daq_data.csv';

% reading .csv
opts = detectImportOptions(filename);
opts.VariableNamingRule = 'preserve';
data = readtable(filename, opts);

% exporting variables
time = data.Time;
vpp = data.Vpp;

% calculating Sampling Frequency / Fs
dt = mean(diff(time)); 
Fs = 1 / dt; 
N = length(vpp);

% signal processing and filtering
% import Moving Average Filter 
windowSize = 15;
vpp_filtered = movmean(vpp, windowSize);

% Noise = Raw - Filtered
noise = vpp - vpp_filtered;

% calculating Signal-to-Noise Ratio (SNR)
snr_raw = snr(vpp, Fs);
snr_clean = snr(vpp_filtered, Fs);

% FIGURE 1: TIME-DOMAIN SIGNAL ANALYSIS
figure('Name', 'DAQ Signal Processing - Time Domain', 'Color', 'w');

% Subplot 1: Raw Data
subplot(3,1,1);
plot(time, vpp, 'Color', [0.85, 0.325, 0.098], 'LineWidth', 1);
title('1. Raw Acquired Signal (Vpp)', 'FontSize', 11);
xlabel('Time (s)'); ylabel('Voltage (V)');
grid on; set(gca, 'Box', 'off');

% Subplot 2: Filtered Data
subplot(3,1,2);
plot(time, vpp_filtered, 'Color', [0, 0.447, 0.741], 'LineWidth', 1.5);
title(sprintf('2. Filtered Signal (Moving Avg, N=%d) | SNR: %.2f dB', windowSize, snr_clean), 'FontSize', 11);
xlabel('Time (s)'); ylabel('Voltage (V)');
grid on; set(gca, 'Box', 'off');

% Subplot 3: Extracted Noise
subplot(3,1,3);
plot(time, noise, 'Color', [0.466, 0.674, 0.188], 'LineWidth', 0.8);
title('3. Isolated Noise Component (Raw - Filtered)', 'FontSize', 11);
xlabel('Time (s)'); ylabel('Noise (V)');
grid on; set(gca, 'Box', 'off');

sgtitle('DAQ Signal Filtering & Noise Extraction Analysis', 'FontSize', 14, 'FontWeight', 'bold');

% FIGURE 2: FREQUENCY SPECTRUM (FFT ANALYSIS)
% calculation of Fast Fourier Transform (FFT)
Y = fft(vpp);
P2 = abs(Y / N);
P1 = P2(1:floor(N/2)+1);
P1(2:end-1) = 2 * P1(2:end-1);
f = Fs * (0:(N/2)) / N;

figure('Name', 'DAQ Signal Processing - Frequency Spectrum', 'Color', 'w');
plot(f, P1, 'Color', [0.494, 0.184, 0.556], 'LineWidth', 1.2);
title('Single-Sided Amplitude Spectrum of Raw Signal (FFT)', 'FontSize', 12, 'FontWeight', 'bold');
xlabel('Frequency (Hz)');
ylabel('|P1(f)| Amplitude');
grid on; set(gca, 'Box', 'off');

% FIGURE 3: STATISTICAL NOISE DISTRIBUTION
figure('Name', 'DAQ Noise Statistical Analysis', 'Color', 'w');
histogram(noise, 40, 'Normalization', 'pdf', 'FaceColor', [0.301, 0.745, 0.933], 'EdgeColor', 'w');
hold on;

% Gaussian Fit
mu = mean(noise);
sigma = std(noise);
x_fit = linspace(min(noise), max(noise), 100);
y_fit = normpdf(x_fit, mu, sigma);
plot(x_fit, y_fit, 'r--', 'LineWidth', 2);

title(sprintf('Noise Statistical Distribution (\\mu = %.4f V, \\sigma = %.4f V)', mu, sigma), 'FontSize', 12, 'FontWeight', 'bold');
xlabel('Noise Amplitude (V)');
ylabel('Probability Density');
legend('Noise Histogram', 'Gaussian Fit', 'Location', 'northeast');
grid on; set(gca, 'Box', 'off');


